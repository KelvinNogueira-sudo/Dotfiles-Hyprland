        "percent": {
          "type": ["bar"]
        } 
    },
    {
      "type": "disk",
      "key": "пӮ ",
      "keyColor": "black",
      "format":
        "{size-percentage-bar} {size-used} / {size-total} [{filesystem}]",
        "percent": {
          "type": ["bar"]
        }
    },
    {
      "type": "battery",
      "key": "пүҖ",
      "keyColor": "black"
    },
    {
      "type": "custom",
      "format": "{#90}в””{$1}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ{$1}в”ҳ{#}"
    },
    
    {
      "type": "custom",
      "format": "{#90}в”Ң{$1} {##b83529}Software {#90}{$1}в”җ{#}"
    },
    {
      "type": "os",
      "key": "оҜҶ",
      "keyColor": "black"
    },
    {
      "type": "kernel",
      "key": "пҖ“",
      "keyColor": "black"
    },
    {
    "type": "terminal",
    "key": "п’ү",
    "keyColor": "black"
    },
    {
      "type": "shell",
      "key": "оҜҠ",
      "keyColor": "black"
    },
    {
      "type": "packages",
      "key": "о¬©",

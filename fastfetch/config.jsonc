{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "type": "auto",
    "source": "arch",
    "padding": {
      "top": 2,
      "left": 2
    },
    "color": {
      "1": "red",
      "2": "light_red" //It's darker actualy
    }
  },
  "display": {
    "separator": "",
    "constants": [
      "в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ"
    ],
    "key": {
      "width": 4
    }
  },
  
  "modules": [
    {
      "type":"title",
      "key":"пҖҮ ",
      "keyColor": "red",
      "format": "{user-name}@{host-name}"
    },
    {
      "type": "custom",
      "format": "{#90}в”Ң{$1} {##b83529}Hardware {#90}{$1}в”җ{#}"
    },
    {
      "type": "cpu",
      "key": "п’ј",
      "keyColor": "black"
    },
    {
      "type": "gpu",
      "key": "у°ў®",
      "keyColor": "black"
    },
    {
      "type": "memory",
      "key": "оҝ…",
      "keyColor": "black",
      "format":
